<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leaderboard - CityWise</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <header class="navbar">
        <div class="nav-left">
            <a href="/" class="logo">CityWise</a>
        </div>

        <div class="nav-center">
            <a href="/" class="nav-tab">Home</a>
            <a href="/cities" class="nav-tab">City Trivia</a>
            <a href="/study" class="nav-tab">Study &amp; Quiz</a>
            <a href="/map" class="nav-tab">Map</a>
            <a href="/leaderboard" class="nav-tab">Leaderboard</a>
            <a href="/statistics" class="nav-tab">Statistics</a>

            <% if (isAdmin) { %>
                <a href="/admin" class="nav-tab">Admin</a>
            <% } %>
        </div>

        <div class="nav-right">
            <% if (!isLoggedIn) { %>
                <a href="/register">Create Account</a>
                <span class="divider">|</span>
                <a href="/login">Log In</a>
            <% } else { %>
                <a href="/profile"><%= username %></a>
                <span class="divider">|</span>
                <a href="/logout">Log Out</a>
            <% } %>
        </div>
    </header>

    <main class="home-container">

        <section class="hero">
            <h1>Leaderboard</h1>
            <p>See how players rank based on quiz performance.</p>
        </section>

        <section class="home-info">
            <% if (!leaderboardRows || leaderboardRows.length === 0) { %>
                <p>No leaderboard data is available yet.</p>
            <% } else { %>
                <div class="city-card">
                    <table class="leaderboard-table">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th>Username</th>
                                <th>Total Points</th>
                                <th>Quizzes Completed</th>
                                <th>Average Score</th>
                                <th>Best Score</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% leaderboardRows.forEach(function(row, index) { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td><%= row.Username %></td>
                                    <td><%= row.TotalQuizPoints %></td>
                                    <td><%= row.QuizzesCompleted %></td>
                                    <td><%= row.AverageScore %></td>
                                    <td><%= row.BestScore %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>

    </main>

</body>
</html>