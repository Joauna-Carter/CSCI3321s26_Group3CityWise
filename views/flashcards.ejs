<!-- flashcards.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Flashcards - CityWise</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .flashcard-wrapper {
            max-width: 900px;
            margin: 0 auto;
            text-align: center;
        }

        .flashcard-scene {
            width: 100%;
            max-width: 700px;
            height: 380px;
            margin: 0 auto 25px auto;
            perspective: 1200px;
        }

        .flashcard {
            width: 100%;
            height: 100%;
            position: relative;
            transition: transform 0.7s ease;
            transform-style: preserve-3d;
            cursor: pointer;
        }

        .flashcard.is-flipped {
            transform: rotateY(180deg);
        }

        .flashcard-face {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            box-sizing: border-box;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
            border: 2px solid #d8c3a5;
        }

        .flashcard-front {
            background: #ffffff;
            color: #1f2937;
        }

        .flashcard-back {
            background: #f7f1e7;
            color: #2d3748;
            transform: rotateY(180deg);
        }

        .flashcard-text {
            font-size: 2rem;
            line-height: 1.4;
            font-weight: 500;
        }

        .flashcard-side-label {
            position: absolute;
            top: 18px;
            right: 22px;
            font-size: 0.95rem;
            font-weight: bold;
            letter-spacing: 0.04em;
            opacity: 0.75;
            text-transform: uppercase;
        }

        .flashcard-controls {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 16px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .flashcard-controls button {
            background: #d8c3a5;
            color: #1f2937;
            border: none;
            border-radius: 12px;
            padding: 10px 18px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
        }

        .flashcard-controls button:hover {
            background: #c9ae88;
        }

        .flashcard-counter {
            font-size: 1.1rem;
            font-weight: bold;
            min-width: 70px;
        }

        .flashcard-hint {
            margin-top: 12px;
            font-size: 0.95rem;
            opacity: 0.8;
        }
    </style>
</head>
<body>

    <header class="navbar">
        <div class="nav-left">
            <a href="/" class="logo">CityWise</a>
        </div>

        <div class="nav-center">
            <a href="/" class="nav-tab">Home</a>
            <a href="/cities" class="nav-tab">City Trivia</a>
            <a href="/study" class="nav-tab">Study &amp; Quiz</a>
            <a href="/map" class="nav-tab">Map</a>
            <a href="/leaderboard" class="nav-tab">Leaderboard</a>
            <a href="/statistics" class="nav-tab">Statistics</a>

            <% if (isAdmin) { %>
                <a href="/admin" class="nav-tab">Admin</a>
            <% } %>
        </div>

        <div class="nav-right">
            <% if (!isLoggedIn) { %>
                <a href="/register">Create Account</a>
                <span class="divider">|</span>
                <a href="/login">Log In</a>
            <% } else { %>
                <a href="/profile"><%= username %></a>
                <span class="divider">|</span>
                <a href="/logout">Log Out</a>
            <% } %>
        </div>
    </header>

    <main class="home-container">
        <section class="hero">
            <h1>Flashcards</h1>
            <p>Click the card to flip it and study one fact at a time.</p>
            <% if (isGuest) { %>
                <p>You are using flashcards as a guest, so this session was not saved.</p>
            <% } %>
        </section>

        <section class="flashcard-wrapper">
            <div class="flashcard-scene">
                <div id="flashcard" class="flashcard">
                    <div class="flashcard-face flashcard-front">
                        <div class="flashcard-side-label">Front</div>
                        <div id="flashcard-front-text" class="flashcard-text"></div>
                    </div>

                    <div class="flashcard-face flashcard-back">
                        <div class="flashcard-side-label">Back</div>
                        <div id="flashcard-back-text" class="flashcard-text"></div>
                    </div>
                </div>
            </div>

            <div class="flashcard-controls">
                <button type="button" onclick="prevCard()">Previous</button>
                <button type="button" onclick="flipCard()">Flip</button>
                <span id="counter" class="flashcard-counter"></span>
                <button type="button" onclick="nextCard()">Next</button>
            </div>

            <p class="flashcard-hint">Front = prompt. Back = answer.</p>
        </section>
    </main>

    <script>
        var flashcards = <%- JSON.stringify(flashcards) %>;
        var currentIndex = 0;
        var showingFront = true;

        function renderCard() {
            var card = flashcards[currentIndex];
            var flashcardEl = document.getElementById("flashcard");
            var frontTextEl = document.getElementById("flashcard-front-text");
            var backTextEl = document.getElementById("flashcard-back-text");
            var counterEl = document.getElementById("counter");

            frontTextEl.textContent = card.frontText;
            backTextEl.textContent = card.backText;
            counterEl.textContent = (currentIndex + 1) + " / " + flashcards.length;

            if (showingFront) {
                flashcardEl.classList.remove("is-flipped");
            } else {
                flashcardEl.classList.add("is-flipped");
            }
        }

        function flipCard() {
            showingFront = !showingFront;
            renderCard();
        }

        function nextCard() {
            currentIndex = (currentIndex + 1) % flashcards.length;
            showingFront = true;
            renderCard();
        }

        function prevCard() {
            currentIndex = (currentIndex - 1 + flashcards.length) % flashcards.length;
            showingFront = true;
            renderCard();
        }

        document.getElementById("flashcard").addEventListener("click", function() {
            flipCard();
        });

        renderCard();
    </script>
</body>
</html>