<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= city.CityName %> - CityWise</title>
  <link rel="stylesheet" href="/css/style.css">

  <style>
    .city-container {
      max-width: 1000px;
      margin: 30px auto;
      padding: 0 20px;
    }

    .wiki-page img,
    .city-image {
      max-width: 600px;
      width: 100%;
      height: auto;
      border-radius: 8px;
      margin-top: 10px;
    }

    .wiki-page table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 12px;
      table-layout: fixed;
    }

    .wiki-page th,
    .wiki-page td {
      border: 1px solid #ccc;
      padding: 10px;
      vertical-align: top;
      white-space: normal;
      overflow-wrap: anywhere;
      word-wrap: break-word;
    }

    .wiki-page th {
      background-color: #f4f4f4;
    }

    .wiki-page .fact-image {
      max-width: 200px;
      width: 100%;
      border-radius: 6px;
    }

    .wiki-page .no-image {
      color: #888;
      font-style: italic;
    }

    .section {
      margin-top: 30px;
    }

    .buttons a,
    .admin-tool-links a {
      display: inline-block;
      margin-right: 10px;
      margin-bottom: 8px;
      padding: 8px 12px;
      background-color: #007BFF;
      color: white;
      text-decoration: none;
      border-radius: 4px;
    }

    .buttons a:hover,
    .admin-tool-links a:hover {
      background-color: #0056b3;
    }

    .admin-tools {
      border: 1px solid #ddd;
      background: #f8f8f8;
      padding: 15px;
      border-radius: 8px;
    }

    .admin-warning {
      background: #fff3cd;
      border: 1px solid #ffeeba;
      padding: 10px;
      border-radius: 6px;
      margin-top: 15px;
    }
  </style>
</head>

<body>

<header class="navbar">
  <div class="nav-left">
    <a href="/" class="logo">CityWise</a>
  </div>

  <div class="nav-center">
    <a href="/" class="nav-tab">Home</a>
    <a href="/cities" class="nav-tab">City Trivia</a>
    <a href="/study" class="nav-tab">Study &amp; Quiz</a>
    <a href="/map" class="nav-tab">Map</a>
    <a href="/leaderboard" class="nav-tab">Leaderboard</a>
    <a href="/statistics" class="nav-tab">Statistics</a>

    <% if (isAdmin) { %>
      <a href="/admin" class="nav-tab">Admin</a>
    <% } %>
  </div>

  <div class="nav-right">
    <% if (!isLoggedIn) { %>
      <a href="/register">Create Account</a>
      <span class="divider">|</span>
      <a href="/login">Log In</a>
    <% } else { %>
      <a href="/profile"><%= username %></a>
      <span class="divider">|</span>
      <a href="/logout">Log Out</a>
    <% } %>
  </div>
</header>

<main class="city-container">

  <% if (isAdmin) { %>
    <div class="section admin-tools">
      <h2>Admin City Tools</h2>

      <div class="admin-tool-links">
        <a href="/admin/cities/<%= city.CityID %>/content">Edit City Page Content</a>
        <a href="/admin/cities/<%= city.CityID %>/history">View Edit History</a>
        <a href="/admin">Admin Dashboard</a>
      </div>

      <% if (city.IsActive) { %>
        <form method="POST" action="/admin/cities/<%= city.CityID %>/hide">
          <button type="submit">Hide City</button>
        </form>
      <% } else { %>
        <form method="POST" action="/admin/cities/<%= city.CityID %>/unhide">
          <button type="submit">Unhide City</button>
        </form>
      <% } %>
    </div>
  <% } %>

  <% if (isAdmin && city.IsActive === 0) { %>
    <div class="admin-warning">
      This city is currently hidden from regular users.
    </div>
  <% } %>

  <div class="wiki-page">
    <% if (pageContent) { %>
      <%- pageContent %>
    <% } else { %>
      <h1><%= city.CityName %></h1>
      <p><strong><%= city.CountryName %></strong> | <%= city.RegionName %></p>

      <% if (city.CityImagePath) { %>
        <p><img class="city-image" src="<%= city.CityImagePath %>" alt="<%= city.CityName %>"></p>
      <% } %>

      <p><%= city.Description %></p>

      <h2>Quick Facts</h2>
      <ul>
        <li><strong>Country:</strong> <%= city.CountryName %></li>

        <% if (city.Population) { %>
          <li><strong>Population:</strong> <%= Number(city.Population).toLocaleString() %></li>
        <% } %>
      </ul>

      <h2>Location</h2>
      <ul>
        <li><strong>Latitude:</strong> <%= city.Latitude %></li>
        <li><strong>Longitude:</strong> <%= city.Longitude %></li>
      </ul>

      <h2>Facts</h2>
      <table>
        <thead>
          <tr>
            <th>Fact</th>
            <th>Image</th>
          </tr>
        </thead>
        <tbody>
          <% funFacts.forEach(function(fact) { %>
            <tr>
              <td>
                <strong><%= fact.FactLabel %>:</strong>
                <%= fact.FactValue %>
              </td>
              <td>
                <% if (fact.FactImagePath) { %>
                  <img class="fact-image" src="<%= fact.FactImagePath %>" alt="<%= fact.FactLabel %>">
                <% } else { %>
                  <span class="no-image">No Image</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>

      <h2>Sources</h2>
      <p>Sources can be added later.</p>
    <% } %>
  </div>

  <div class="section">
    <h2>Test Your Knowledge</h2>

    <div class="buttons">
      <a href="/study?mode=quiz&cityId=<%= city.CityID %>">Start Quiz on <%= city.CityName %></a>
      <a href="/flashcards/start?cityId=<%= city.CityID %>">Study Flashcards</a>
    </div>
  </div>

</main>

</body>
</html>