<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Statistics - CityWise</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <header class="navbar">
        <div class="nav-left">
            <a href="/" class="logo">CityWise</a>
        </div>

        <div class="nav-center">
            <a href="/" class="nav-tab">Home</a>
            <a href="/cities" class="nav-tab">City Trivia</a>
            <a href="/study" class="nav-tab">Study &amp; Quiz</a>
            <a href="/map" class="nav-tab">Map</a>
            <a href="/leaderboard" class="nav-tab">Leaderboard</a>
            <a href="/statistics" class="nav-tab">Statistics</a>

            <% if (isAdmin) { %>
                <a href="/admin" class="nav-tab">Admin</a>
            <% } %>
        </div>

        <div class="nav-right">
            <% if (!isLoggedIn) { %>
                <a href="/register">Create Account</a>
                <span class="divider">|</span>
                <a href="/login">Log In</a>
            <% } else { %>
                <a href="/profile"><%= username %></a>
                <span class="divider">|</span>
                <a href="/logout">Log Out</a>
            <% } %>
        </div>
    </header>

    <main class="home-container">

        <section class="hero">
            <h1>Statistics</h1>
            <p>View website statistics and your personal progress.</p>
        </section>

        <section class="home-info">
            <h2>Website Statistics</h2>

            <% if (!websiteStats) { %>
                <p>No website statistics are available yet.</p>
            <% } else { %>
                <div class="city-grid">
                    <div class="city-card">
                        <h3>Total Users</h3>
                        <p><%= websiteStats.TotalUsers %></p>
                    </div>

                    <div class="city-card">
                        <h3>Total Admins</h3>
                        <p><%= websiteStats.TotalAdmins %></p>
                    </div>

                    <div class="city-card">
                        <h3>Total Regular Users</h3>
                        <p><%= websiteStats.TotalRegularUsers %></p>
                    </div>

                    <div class="city-card">
                        <h3>Total Quizzes Completed</h3>
                        <p><%= websiteStats.TotalQuizzesCompleted %></p>
                    </div>

                    <div class="city-card">
                        <h3>Average Quiz Score</h3>
                        <p><%= Number(websiteStats.AverageQuizScore || 0).toFixed(2) %></p>
                    </div>

                    <div class="city-card">
                        <h3>Highest Quiz Score</h3>
                        <p><%= websiteStats.HighestQuizScore %></p>
                    </div>

                    <div class="city-card">
                        <h3>Most Popular Quiz Mode</h3>
                        <p><%= websiteStats.MostPopularQuizMode || "None" %></p>
                    </div>

                    <div class="city-card">
                        <h3>Total Flashcard Sessions</h3>
                        <p><%= websiteStats.TotalFlashcardSessions %></p>
                    </div>
                </div>
            <% } %>
        </section>

        <section class="home-info" style="margin-top: 30px;">
            <h2>Your Statistics</h2>

            <% if (!userStats) { %>
                <p>Log in to view your personal statistics.</p>
            <% } else { %>
                <div class="city-grid">
                    <div class="city-card">
                        <h3>Quizzes Completed</h3>
                        <p><%= userStats.QuizzesCompleted %></p>
                    </div>

                    <div class="city-card">
                        <h3>Average Score</h3>
                        <p><%= Number(userStats.AverageScore || 0).toFixed(2) %></p>
                    </div>

                    <div class="city-card">
                        <h3>Best Score</h3>
                        <p><%= userStats.BestScore %></p>
                    </div>

                    <div class="city-card">
                        <h3>Total Quiz Points</h3>
                        <p><%= userStats.TotalQuizPoints %></p>
                    </div>

                    <div class="city-card">
                        <h3>Flashcard Sessions Used</h3>
                        <p><%= userStats.FlashcardSessionsUsed %></p>
                    </div>

                    <div class="city-card">
                        <h3>Most Used Quiz Mode</h3>
                        <p><%= userStats.MostDoneQuizMode || "N/A" %></p>
                    </div>
                </div>

                <div class="city-card" style="margin-top: 20px;">
                    <p><strong>Last Quiz Attempted:</strong> <%= userStats.LastQuizAttemptedAt || "N/A" %></p>
                </div>
            <% } %>
        </section>

    </main>

</body>
</html>