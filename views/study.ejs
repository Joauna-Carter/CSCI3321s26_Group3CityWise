<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Study & Quiz - CityWise</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <header class="navbar">
        <div class="nav-left">
            <a href="/" class="logo">CityWise</a>
        </div>

        <div class="nav-center">
            <a href="/" class="nav-tab">Home</a>
            <a href="/cities" class="nav-tab">City Trivia</a>
            <a href="/study" class="nav-tab">Study &amp; Quiz</a>
            <a href="/map" class="nav-tab">Map</a>
            <a href="/leaderboard" class="nav-tab">Leaderboard</a>
            <a href="/statistics" class="nav-tab">Statistics</a>

            <% if (isAdmin) { %>
                <a href="/admin" class="nav-tab">Admin</a>
            <% } %>
        </div>

        <div class="nav-right">
            <% if (!isLoggedIn) { %>
                <a href="/register">Create Account</a>
                <span class="divider">|</span>
                <a href="/login">Log In</a>
            <% } else { %>
                <a href="/profile"><%= username %></a>
                <span class="divider">|</span>
                <a href="/logout">Log Out</a>
            <% } %>
        </div>
    </header>

    <main class="home-container">

        <section class="hero">
            <h1>Study &amp; Quiz</h1>
            <p>
                Choose how you want to learn. You can start a quiz or study with flashcards
                using a single city, a region, or a random set of cities.
            </p>
        </section>

        <section class="home-info">
            <h2>Start an Activity</h2>

            <form method="POST" action="/study/start" class="city-card">

                <p>
                    <label for="mode"><strong>Mode</strong></label><br>
                    <select name="mode" id="mode">
                        <option value="quiz" <%= mode === "quiz" ? "selected" : "" %>>Quiz</option>
                        <option value="flashcards" <%= mode === "flashcards" ? "selected" : "" %>>Flashcards</option>
                    </select>
                </p>

                <p>
                    <label for="cityId"><strong>Single City</strong></label><br>
                    <select name="cityId" id="cityId">
                        <option value="">None</option>
                        <% if (cities && cities.length > 0) { %>
                            <% cities.forEach(function(city) { %>
                                <option value="<%= city.CityID %>" <%= String(selectedCityId) === String(city.CityID) ? "selected" : "" %>>
                                    <%= city.CityName %>
                                </option>
                            <% }) %>
                        <% } %>
                    </select>
                </p>

                <p>
                    <label for="regionId"><strong>Region</strong></label><br>
                    <select name="regionId" id="regionId">
                        <option value="">None</option>
                        <% if (regions && regions.length > 0) { %>
                            <% regions.forEach(function(region) { %>
                                <option value="<%= region.RegionID %>"><%= region.RegionName %></option>
                            <% }) %>
                        <% } %>
                    </select>
                </p>

                <p>
                    <label for="requestedCityCount"><strong>Random City Count</strong></label><br>
                    <input type="number" name="requestedCityCount" id="requestedCityCount" min="1" max="20" value="5">
                </p>

                <p>
                    <label for="difficulty"><strong>Difficulty</strong></label><br>
                    <select name="difficulty" id="difficulty">
                        <option value="easy">Easy</option>
                        <option value="medium">Medium</option>
                        <option value="hard">Hard</option>
                    </select>
                </p>

                <p>
                    <label>
                        <input type="checkbox" name="timed" value="1">
                        Timed Mode
                    </label>
                </p>

                <p>
                    <button type="submit">Start Activity</button>
                </p>
            </form>
        </section>

        <section class="home-info">
            <h2>How It Works</h2>

            <div class="city-grid">

                <div class="city-card">
                    <h3>Single City</h3>
                    <p>
                        Pick one city to focus on that city’s facts, quiz questions,
                        and flashcards.
                    </p>
                </div>

                <div class="city-card">
                    <h3>Region Mode</h3>
                    <p>
                        Choose a region and let CityWise select cities from that area
                        for a broader activity.
                    </p>
                </div>

                <div class="city-card">
                    <h3>Random Mode</h3>
                    <p>
                        Set a number of cities and let the system build a random quiz
                        or flashcard session.
                    </p>
                </div>

                <div class="city-card">
                    <h3>Difficulty</h3>
                    <p>
                        Easy gives fewer questions, while medium and hard increase
                        the number of questions in the quiz.
                    </p>
                </div>

            </div>
        </section>

    </main>

</body>
</html>