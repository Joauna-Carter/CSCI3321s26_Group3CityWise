<!-- admin.ejs -->
<!-- Renders the admin dashboard with links to every database table available to admins -->

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Sets page character encoding -->
    <meta charset="UTF-8">

    <!-- Makes layout responsive on different screen sizes -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Browser tab title -->
    <title>Admin - CityWise</title>

    <!-- Loads shared site styling -->
    <link rel="stylesheet" href="/css/style.css">

    <style>
        /* Grid layout for database table cards */
        .admin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 18px;
        }

        /* Card for each database table */
        .admin-card {
            background: white;
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 18px;
        }

        /* Button-style table links */
        .admin-card a {
            display: inline-block;
            margin-top: 8px;
            padding: 8px 12px;
            background: #1f2937;
            color: white;
            text-decoration: none;
            border-radius: 8px;
        }

        /* Darkens table link on hover */
        .admin-card a:hover {
            background: #374151;
        }

        /* Notice explaining hide behavior */
        .admin-note {
            background: #fff8e6;
            border: 1px solid #e0c67a;
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 20px;
        }
    </style>
</head>

<body>

<!-- Main navigation bar -->
<header class="navbar">
    <!-- Site logo -->
    <div class="nav-left">
        <a href="/" class="logo">CityWise</a>
    </div>

    <!-- Main navigation links -->
    <div class="nav-center">
        <a href="/" class="nav-tab">Home</a>
        <a href="/cities" class="nav-tab">City Trivia</a>
        <a href="/study" class="nav-tab">Study &amp; Quiz</a>
        <a href="/map" class="nav-tab">Map</a>
        <a href="/leaderboard" class="nav-tab">Leaderboard</a>
        <a href="/statistics" class="nav-tab">Statistics</a>
        <a href="/admin" class="nav-tab">Admin</a>
    </div>

    <!-- Logged-in admin controls -->
    <div class="nav-right">
        <a href="/profile"><%= username %></a>
        <span class="divider">|</span>
        <a href="/logout">Log Out</a>
    </div>
</header>

<!-- Main dashboard content -->
<main class="home-container">

    <!-- Dashboard heading -->
    <section class="hero">
        <h1>Admin Dashboard</h1>
        <p>Manage all CityWise database tables using searchable table editors.</p>
    </section>

    <!-- Explains which tables can hide rows -->
    <div class="admin-note">
        Rows are hidden using IsActive when the table supports it. System and relationship tables are view/edit only and do not use hide controls.
    </div>

    <!-- Builds one card per table from adminRoutes.js table metadata -->
    <section class="admin-grid">
        <% tables.forEach(function(table) { %>
            <div class="admin-card">
                <!-- User-friendly table label -->
                <h2><%= table.label %></h2>

                <!-- Actual database table name -->
                <p><strong>Database table:</strong> <%= table.table %></p>

                <!-- Shows whether the table supports IsActive hide/unhide -->
                <p><strong>Hide support:</strong> <%= table.hasIsActive ? "Yes" : "No" %></p>

                <!-- Opens the generic table editor for this table -->
                <a href="/admin/database/<%= table.slug %>">Open Table</a>
            </div>
        <% }) %>
    </section>

</main>

</body>
</html>