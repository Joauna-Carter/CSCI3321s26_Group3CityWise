<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - CityWise</title>
    <link rel="stylesheet" href="/css/style.css">

    <style>
        .admin-grid {
            display: grid;
            gap: 24px;
        }

        .admin-card {
            background: white;
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 20px;
        }

        .admin-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 12px;
        }

        .admin-table th,
        .admin-table td {
            border: 1px solid #ddd;
            padding: 8px;
        }

        .inline-form {
            display: inline;
        }

        .search-bar {
            width: 100%;
            padding: 10px;
            margin-bottom: 10px;
        }

        .admin-links a {
            display: inline-block;
            margin-right: 10px;
            padding: 8px 12px;
            background: #1f2937;
            color: white;
            text-decoration: none;
            border-radius: 8px;
        }

        .admin-links a:hover {
            background: #374151;
        }

        .admin-form input,
        .admin-form select {
            display: block;
            width: 100%;
            margin-bottom: 10px;
            padding: 8px;
        }

        .admin-form button {
            padding: 10px 14px;
            background: #007BFF;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }

        .admin-form button:hover {
            background: #0056b3;
        }
    </style>
</head>
<body>

<header class="navbar">
    <div class="nav-left">
        <a href="/" class="logo">CityWise</a>
    </div>

    <div class="nav-center">
        <a href="/" class="nav-tab">Home</a>
        <a href="/cities" class="nav-tab">City Trivia</a>
        <a href="/study" class="nav-tab">Study &amp; Quiz</a>
        <a href="/map" class="nav-tab">Map</a>
        <a href="/leaderboard" class="nav-tab">Leaderboard</a>
        <a href="/statistics" class="nav-tab">Statistics</a>
        <a href="/admin" class="nav-tab">Admin</a>
    </div>

    <div class="nav-right">
        <a href="/profile"><%= username %></a>
        <span class="divider">|</span>
        <a href="/logout">Log Out</a>
    </div>
</header>

<main class="home-container">

    <section class="hero">
        <h1>Admin Dashboard</h1>
        <p>Manage database content in a clean, searchable interface.</p>
    </section>

    <!-- DATABASE LINKS -->
    <div class="admin-links">
        <a href="/admin/database/cities">Cities Table</a>
        <a href="/admin/database/countries">Countries Table</a>
        <a href="/admin/database/regions">Regions Table</a>
        <a href="/admin/database/facts">City Facts</a>
        <a href="/admin/database/questions">Custom Questions</a>
    </div>

    <div class="admin-grid">

        <!-- MANAGE CITIES -->
        <section class="admin-card">
            <h2>Manage Cities</h2>

            <input type="text" id="citySearch" class="search-bar" placeholder="Search cities...">

            <table class="admin-table" id="cityTable">
                <thead>
                    <tr>
                        <th>City</th>
                        <th>Country</th>
                        <th>Region</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <% cities.forEach(function(city) { %>
                        <tr>
                            <td><%= city.CityName %></td>
                            <td><%= city.CountryName %></td>
                            <td><%= city.RegionName %></td>
                            <td><%= city.IsActive ? "Active" : "Hidden" %></td>
                            <td>
                                <a href="/cities/<%= city.CityID %>">View</a>

                                <% if (city.IsActive) { %>
                                    <form action="/admin/cities/<%= city.CityID %>/hide" method="POST" class="inline-form">
                                        <button type="submit">Hide</button>
                                    </form>
                                <% } else { %>
                                    <form action="/admin/cities/<%= city.CityID %>/unhide" method="POST" class="inline-form">
                                        <button type="submit">Unhide</button>
                                    </form>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </section>

        <!-- QUICK ADD CITY -->
        <section class="admin-card">
            <h2>Quick Add City</h2>

            <form action="/admin/cities/add" method="POST" class="admin-form">

                <input type="text" name="name" placeholder="City Name" required>

                <select name="countryId" required>
                    <option value="">Select Country</option>
                    <% countries.forEach(function(c) { %>
                        <option value="<%= c.CountryID %>">
                            <%= c.CountryName %> (<%= c.RegionName %>)
                        </option>
                    <% }) %>
                </select>

                <input type="text" name="population" placeholder="Population (e.g., 3,900,000)">
                <input type="text" name="lat" placeholder="Latitude">
                <input type="text" name="lng" placeholder="Longitude">
                <input type="text" name="image" placeholder="Image URL">

                <button type="submit">Add City</button>

            </form>
        </section>

    </div>

</main>

<script>
document.getElementById("citySearch").addEventListener("keyup", function() {
    let filter = this.value.toLowerCase();
    let rows = document.querySelectorAll("#cityTable tbody tr");

    rows.forEach(row => {
        let text = row.innerText.toLowerCase();
        row.style.display = text.includes(filter) ? "" : "none";
    });
});
</script>

</body>
</html>