<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - CityWise</title>
    <link rel="stylesheet" href="/css/style.css">

    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

    <style>
        #editor {
            height: 280px;
            background: white;
        }

        .admin-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 24px;
        }

        .admin-card {
            background: white;
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 20px;
        }

        .admin-card h2 {
            margin-top: 0;
        }

        .admin-form {
            display: grid;
            gap: 12px;
        }

        .admin-form input,
        .admin-form textarea,
        .admin-form select,
        .admin-form button {
            padding: 10px;
            font-size: 1rem;
        }

        .admin-message {
            margin-bottom: 20px;
            padding: 12px;
            border-radius: 10px;
            background: #eef6ff;
            border: 1px solid #b8d8ff;
        }

        .facts-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 12px;
        }

        .facts-table th,
        .facts-table td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
            vertical-align: top;
        }
    </style>
</head>
<body>

    <header class="navbar">
        <div class="nav-left">
            <a href="/" class="logo">CityWise</a>
        </div>

        <div class="nav-center">
            <a href="/" class="nav-tab">Home</a>
            <a href="/cities" class="nav-tab">City Trivia</a>
            <a href="/study" class="nav-tab">Study &amp; Quiz</a>
            <a href="/map" class="nav-tab">Map</a>
            <a href="/leaderboard" class="nav-tab">Leaderboard</a>
            <a href="/statistics" class="nav-tab">Statistics</a>
            <a href="/admin" class="nav-tab">Admin</a>
        </div>

        <div class="nav-right">
            <a href="/profile"><%= username %></a>
            <span class="divider">|</span>
            <a href="/logout">Log Out</a>
        </div>
    </header>

    <main class="home-container">
        <section class="hero">
            <h1>Admin Dashboard</h1>
            <p>Manage cities, facts, and city page content from one place.</p>
        </section>

        <% if (message) { %>
            <div class="admin-message">
                <%= message %>
            </div>
        <% } %>

        <div class="admin-grid">

            <section class="admin-card">
                <h2>Add City</h2>

                <form action="/admin/cities/add" method="POST" class="admin-form">
                    <label for="cityName">City Name</label>
                    <input type="text" id="cityName" name="cityName" required>

                    <label for="countryId">Country</label>
                    <select id="countryId" name="countryId" required>
                        <option value="">Select a country</option>
                        <% countries.forEach(function(country) { %>
                            <option value="<%= country.CountryID %>">
                                <%= country.CountryName %> (<%= country.RegionName %>)
                            </option>
                        <% }) %>
                    </select>

                    <label for="population">Population</label>
                    <input type="number" id="population" name="population">

                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="4"></textarea>

                    <label for="latitude">Latitude</label>
                    <input type="text" id="latitude" name="latitude">

                    <label for="longitude">Longitude</label>
                    <input type="text" id="longitude" name="longitude">

                    <label for="cityImagePath">City Image Path</label>
                    <input type="text" id="cityImagePath" name="cityImagePath">

                    <button type="submit">Add City</button>
                </form>
            </section>

            <section class="admin-card">
                <h2>Add Fact</h2>

                <form action="/admin/facts/add" method="POST" class="admin-form">
                    <label for="factCityId">City</label>
                    <select id="factCityId" name="cityId" required>
                        <option value="">Select a city</option>
                        <% cities.forEach(function(city) { %>
                            <option value="<%= city.CityID %>">
                                <%= city.CityName %>, <%= city.CountryName %>
                            </option>
                        <% }) %>
                    </select>

                    <label for="factType">Fact Type</label>
                    <select id="factType" name="factType" required>
                        <option value="QuickFact">QuickFact</option>
                        <option value="FunFact">FunFact</option>
                    </select>

                    <label for="factSubtype">Fact Subtype</label>
                    <input type="text" id="factSubtype" name="factSubtype" placeholder="General, Geography, Culture, Landmark, History..." required>

                    <label for="factLabel">Fact Label</label>
                    <input type="text" id="factLabel" name="factLabel" placeholder="Population, Demonym, Nickname..." required>

                    <label for="factValue">Fact Value</label>
                    <textarea id="factValue" name="factValue" rows="3" required></textarea>

                    <label for="altAnswers">Alt Answers</label>
                    <input type="text" id="altAnswers" name="altAnswers" placeholder="separate with | or comma">

                    <label for="factImageType">Fact Image Type</label>
                    <input type="text" id="factImageType" name="factImageType" placeholder="optional">

                    <button type="submit">Add Fact</button>
                </form>
            </section>

            <section class="admin-card">
                <h2>Edit City Page Content</h2>

                <form action="/admin/content/save" method="POST" class="admin-form" id="contentForm">
                    <label for="contentCityId">Choose City</label>
                    <select id="contentCityId" name="cityId" required onchange="window.location='/admin?cityId=' + this.value">
                        <option value="">Select a city</option>
                        <% cities.forEach(function(city) { %>
                            <option value="<%= city.CityID %>" <%= selectedCity && String(selectedCity.CityID) === String(city.CityID) ? "selected" : "" %>>
                                <%= city.CityName %>, <%= city.CountryName %>
                            </option>
                        <% }) %>
                    </select>

                    <input type="hidden" name="pageContent" id="pageContent">

                    <div id="editor"><%- selectedPageContent || "" %></div>

                    <button type="submit">Save Page Content</button>
                </form>

                <% if (selectedCity) { %>
                    <hr style="margin: 24px 0;">

                    <h3>Current City Data</h3>
                    <p><strong>City:</strong> <%= selectedCity.CityName %>, <%= selectedCity.CountryName %></p>
                    <p><strong>Region:</strong> <%= selectedCity.RegionName %></p>
                    <p><strong>Description:</strong> <%= selectedCity.Description || "No description yet" %></p>

                    <h3>Current Facts</h3>
                    <% if (selectedFacts.length === 0) { %>
                        <p>No facts yet for this city.</p>
                    <% } else { %>
                        <table class="facts-table">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Subtype</th>
                                    <th>Label</th>
                                    <th>Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% selectedFacts.forEach(function(fact) { %>
                                    <tr>
                                        <td><%= fact.FactType %></td>
                                        <td><%= fact.FactSubtype %></td>
                                        <td><%= fact.FactLabel %></td>
                                        <td><%= fact.FactValue %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } %>
                <% } %>
            </section>

        </div>
    </main>

    <script>
        var quill = new Quill("#editor", {
            theme: "snow",
            placeholder: "Write the city page here...",
            modules: {
                toolbar: [
                    [{ header: [1, 2, 3, false] }],
                    ["bold", "italic", "underline"],
                    [{ color: [] }, { background: [] }],
                    [{ list: "ordered" }, { list: "bullet" }],
                    ["link"],
                    ["clean"]
                ]
            }
        });

        document.getElementById("contentForm").onsubmit = function() {
            document.getElementById("pageContent").value = quill.root.innerHTML;
        };
    </script>

</body>
</html>