<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>City Trivia - CityWise</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <header class="navbar">
        <div class="nav-left">
            <a href="/" class="logo">CityWise</a>
        </div>

        <div class="nav-center">
            <a href="/" class="nav-tab">Home</a>
            <a href="/cities" class="nav-tab">City Trivia</a>
            <a href="/study" class="nav-tab">Study &amp; Quiz</a>
            <a href="/map" class="nav-tab">Map</a>
            <a href="/leaderboard" class="nav-tab">Leaderboard</a>
            <a href="/statistics" class="nav-tab">Statistics</a>

            <% if (isAdmin) { %>
                <a href="/admin" class="nav-tab">Admin</a>
            <% } %>
        </div>

        <div class="nav-right">
            <% if (!isLoggedIn) { %>
                <a href="/register">Create Account</a>
                <span class="divider">|</span>
                <a href="/login">Log In</a>
            <% } else { %>
                <a href="/profile"><%= username %></a>
                <span class="divider">|</span>
                <a href="/logout">Log Out</a>
            <% } %>
        </div>
    </header>

    <main class="home-container">

        <section class="hero">
            <h1>City Trivia</h1>
            <p>Browse all available cities and open each city page to learn more.</p>
        </section>

        <section class="home-info">
            <% if (!cities || cities.length === 0) { %>
                <p>No cities are available yet.</p>
            <% } else { %>
                <div class="city-grid">
                    <% cities.forEach(function(city) { %>
                        <div class="city-card">
                            <h3>
                                <a href="/cities/<%= city.CityID %>"><%= city.CityName %></a>
                            </h3>

                            <p><strong>Country:</strong> <%= city.CountryName %></p>
                            <p><strong>Region:</strong> <%= city.RegionName %></p>

                            <% if (city.Description) { %>
                                <p><%= city.Description %></p>
                            <% } else { %>
                                <p>No description available yet.</p>
                            <% } %>

                            <p>
                                <a href="/cities/<%= city.CityID %>">View City Page</a>
                            </p>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </section>

    </main>

</body>
</html>